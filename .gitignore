# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# superpowers brainstorming
/.superpowers/

# Member photos — kept out of git for privacy (EXIF metadata) and
# blob bloat. Files live on the server filesystem and are served
# directly; swap them there without touching the repo.
/public/members/

# Admin-uploaded images (runtime assets, not git-tracked).
# .gitkeep in each subdirectory is preserved.
/public/uploads/*/*
!/public/uploads/*/.gitkeep

# typescript
*.tsbuildinfo
next-env.d.ts
